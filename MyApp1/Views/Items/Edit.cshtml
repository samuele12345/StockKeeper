@model MyApp1.Models.Items;

@{
    ViewData["Title"] = "Edit";
}

<h3>Edit an item</h3>

<form asp-action="Edit" method="post">
    <!--ottiene l'id del modello da editare con un input hidden-->
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label for="Name">Name: </label>
        <input type="text" class="form-control" asp-for="Name" />
    </div>
    <div class="form-group">
        <label for="Price">Price: </label>
        <input type="number" class="form-control" asp-for="Price" />
    </div>
    <br>
    <!--btn-primary da un colore azzurro caratteristico al bottone, classe pre impostata-->
    <button type="submit" class="btn btn-primary">Submit</button>
</form>